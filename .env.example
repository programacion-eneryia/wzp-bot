# =============================================================================
# Plantilla de variables de entorno. Copia este archivo a `.env` y rellena.
# NUNCA pongas claves reales aquí: este archivo SÍ se sube al repositorio.
# Las claves reales van en `.env` (ignorado por git).
# =============================================================================

# --- App ---
NODE_ENV=development
API_PORT=3001
WEB_URL=http://localhost:3000
API_URL=http://localhost:3001
# Orígenes permitidos por CORS (coma-separados). Si vacío, usa WEB_URL.
CORS_ORIGINS=http://localhost:3000
# URL pública base donde Meta/GHL/ManyChat/Unipile envían webhooks (ngrok en local).
WEBHOOK_BASE_URL=

# --- Supabase (base de datos + auth) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# --- Redis (colas BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Unipile (canales + calendario) ---
UNIPILE_DSN=
UNIPILE_API_KEY=
UNIPILE_WEBHOOK_SECRET=

# --- OpenRouter (LLM) ---
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=

# --- Cifrado a nivel de campo (secretos en reposo: API keys, tokens) ---
# OBLIGATORIA para cifrar secretos. Genera con: openssl rand -base64 32 (32 bytes).
FIELD_ENCRYPTION_KEY=

# --- Meta / WhatsApp Cloud API (Fase 2: primer toque oficial + atribución) ---
# ID de tu app de Meta (necesario para el Embedded Signup / canje del code).
META_APP_ID=
# Token de verificación que tú eliges para el handshake del webhook (GET hub.verify_token).
META_WEBHOOK_VERIFY_TOKEN=
# App Secret de tu app de Meta (para verificar la firma X-Hub-Signature-256).
META_APP_SECRET=
# Token de la Conversions API (puede ser el mismo de la app/sistema).
META_CAPI_TOKEN=
# Versión del Graph API a usar (ej. v23.0).
META_GRAPH_VERSION=v23.0

# --- Frontend: Embedded Signup de WhatsApp (públicas, se exponen al navegador) ---
# App ID de Meta y configuration_id del flujo de Embedded Signup (WhatsApp).
NEXT_PUBLIC_META_APP_ID=
NEXT_PUBLIC_META_CONFIG_ID=
# URL base de la API para el frontend.
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Stripe (fase posterior) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
