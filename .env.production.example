# =============================================================================
# Variables para PRODUCCIÓN. NO se commitea con valores reales.
# Se cargan en DOS sitios distintos:
#   - API  -> AWS App Runner (variables de RUNTIME del servicio)
#   - WEB  -> AWS Amplify    (variables de BUILD-TIME; las NEXT_PUBLIC_* se
#             "hornean" en el build, por eso van en Amplify, no en App Runner)
# =============================================================================

# ###########################################################################
# # API  (App Runner -> servicio en puerto 3001)
# ###########################################################################
NODE_ENV=production
API_PORT=3001

# URLs públicas (rellenar tras crear los servicios).
WEB_URL=https://<tu-app>.amplifyapp.com
API_URL=https://<tu-api>.eu-central-1.awsapprunner.com
# CORS: dominios del frontend que pueden llamar a la API (coma-separados).
CORS_ORIGINS=https://<tu-app>.amplifyapp.com
# Base pública donde llegan los webhooks (= URL de la API en App Runner).
WEBHOOK_BASE_URL=https://<tu-api>.eu-central-1.awsapprunner.com

# Supabase (mismo proyecto que ya usas, en eu-central-1).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Redis (Upstash, con TLS -> usa el esquema rediss://).
REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379

# Unipile (canales + calendario).
UNIPILE_DSN=
UNIPILE_API_KEY=
UNIPILE_WEBHOOK_SECRET=

# OpenRouter (LLM).
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=

# Cifrado de secretos en reposo (OBLIGATORIA). Genera: openssl rand -base64 32
FIELD_ENCRYPTION_KEY=

# Meta / WhatsApp Cloud API (opcional, fase 2).
META_APP_ID=
META_WEBHOOK_VERIFY_TOKEN=
META_APP_SECRET=
META_CAPI_TOKEN=
META_GRAPH_VERSION=v23.0

# ###########################################################################
# # WEB  (Amplify -> variables de entorno del build)
# ###########################################################################
NEXT_PUBLIC_API_URL=https://<tu-api>.eu-central-1.awsapprunner.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_META_APP_ID=
NEXT_PUBLIC_META_CONFIG_ID=
